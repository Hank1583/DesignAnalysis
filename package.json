{
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start -H 127.0.0.1 -p 3000",
    "pages:build": "npx @cloudflare/next-on-pages@1",
    "preview": "npx @cloudflare/next-on-pages@1 --skip-build && npx wrangler pages dev .vercel/output/static",
    "deploy": "npm run pages:build && npx wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "next": "15.3.3",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1",
    "wrangler": "^4.97.0"
  }
}
